---
import '../styles/custom.css';

const {
  title = 'NexGen Binary',
  description = 'NexGen Binary provides dental-focused managed IT, security, cloud, and support services across Virginia.',
  site
} = Astro.props;

const formEndpoint = site?.contact?.formEndpoint || '';
const assetBase = import.meta.env.BASE_URL ?? '/';
const assetUrl = (path) => `${assetBase}${path}`;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://cdn.jsdelivr.net" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Plus+Jakarta+Sans:wght@600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="shortcut icon" href={assetUrl('favicon.ico?v=46')} />
    <link rel="icon" type="image/x-icon" href={assetUrl('favicon.ico?v=46')} />
    <link rel="icon" type="image/png" sizes="32x32" href={assetUrl('favicon-32x32.png?v=46')} />
    <link rel="icon" type="image/png" sizes="16x16" href={assetUrl('favicon-16x16.png?v=46')} />
    <link rel="apple-touch-icon" href={assetUrl('apple-touch-icon.png?v=46')} />
    <link rel="manifest" href={assetUrl('site.webmanifest?v=46')} />
    <meta name="theme-color" content="#0b2f53" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <script is:inline>
      if ('scrollRestoration' in history) history.scrollRestoration = 'manual';
      window.addEventListener('load', () => {
        try { window.scrollTo({ top: 0, left: 0, behavior: 'auto' }); } catch { window.scrollTo(0, 0); }
      });
    </script>
  </head>
  <body>
    <slot />
    <script is:inline define:vars={{ formEndpoint }}>
      window.__NEXGEN_FORM_ENDPOINT__ = formEndpoint;
    </script>
  </body>
</html>
