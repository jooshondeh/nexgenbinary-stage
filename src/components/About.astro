---
const { site } = Astro.props;
import IconBadge from "./IconBadge.astro";

const a = site.about ?? {};

const intro =
  a.intro ??
  "NexGen Binary helps dental and healthcare practices keep systems secure, support responsive, and daily operations running smoothly.";

const defaultCards = [
  {
    icon: "people",
    title: "Who We Are",
    items: [
      "Virginia-based IT partner for dental and healthcare practices",
      "Reliable, people-first support with clear follow-through",
      "Guidance shaped by clinical, front-office, and admin workflows",
      "Long-term partnerships focused on clarity, stability, and results",
    ],
  },
  {
    icon: "tools",
    title: "Dental & Healthcare Focus",
    items: [
      "Support across front-office, clinical, and admin systems",
      "Coordination with providers, office managers, and vendors",
      "Planning that reduces disruption during upgrades and transitions",
      "Solutions aligned to daily operations, growth, and patient service",
    ],
  },
  {
    icon: "shield",
    title: "Security & Compliance by Design",
    items: [
      "HIPAA-aware IT practices backed by security-minded planning",
      "Secure access, encryption, backups, and device protection",
      "Documented changes, vendor coordination, and accountability",
      "Cybersecurity safeguards aligned to risk, uptime, and continuity",
    ],
  },
  {
    icon: "checkcircle",
    title: "Leadership & Delivery Experience",
    items: [
      "20+ years of combined IT leadership and delivery experience",
      "Structured onboarding, clear recommendations, and next steps",
      "Licensed and insured service delivered with accountability",
      "Enterprise discipline delivered with local responsiveness",
    ],
  },
];

const cards = Array.isArray(a.cards) && a.cards.length ? a.cards : defaultCards;
---
<section id="about" class="nb-anchor-offset nb-section nb-about-section" style="background:#f8fafc">
  <div class="nb-shell">
    <div class="nb-section-header nb-section-header--left nb-about-header">
      <h2 class="nb-section-title">{a.title ?? "About"}</h2>
      <p class="nb-section-subtitle nb-about-intro">{intro}</p>
    </div>

    <div class="nb-about-grid">
      {cards.map((card) => (
        <article class="nb-card nb-pop bg-white nb-about-panel">
          <div class="nb-about-panel__head">
            <div class="nb-icon-wrap nb-about-panel__icon"><IconBadge name={card.icon} /></div>
            <h3 class="nb-about-panel__title">{card.title}</h3>
          </div>

          <ul class="nb-about-panel__list">
            {(card.items ?? []).map((item) => <li>{item}</li>)}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .nb-about-header {
    margin-bottom: 1rem;
  }

  .nb-about-intro {
    max-width: 880px;
    color: #5b6f84;
    font-size: clamp(1rem, 1.02vw, 1.1rem);
    line-height: 1.46;
    letter-spacing: 0.004em;
  }

  .nb-about-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    align-items: stretch;
    grid-auto-rows: 1fr;
  }

  .nb-about-panel {
    min-height: 272px;
    border-radius: 22px;
    padding: 1.16rem 1.18rem 1.04rem;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .nb-about-panel__head {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 0.44rem;
  }

  .nb-about-panel__icon {
    width: 52px;
    height: 52px;
    min-width: 52px;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 0;
  }

  .nb-about-panel__icon :global(.nb-icon-badge),
  .nb-about-panel__icon :global(.nb-icon-badge svg) {
    width: 26px;
    height: 26px;
    display: block;
  }

  .nb-about-panel__title {
    margin: 0;
    color: #163659;
    font-size: 1.04rem;
    line-height: 1.24;
    letter-spacing: -0.005em;
    font-weight: 700;
  }

  .nb-about-panel__list {
    margin: 0.48rem 0 0;
    padding-left: 1.14rem;
    display: grid;
    gap: 0.46rem;
  }

  .nb-about-panel__list li {
    color: #4f6377;
    line-height: 1.38;
  }

  .nb-about-panel__list li::marker {
    color: #4c6177;
  }

  @media (max-width: 991px) {
    .nb-about-grid {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .nb-about-panel {
      min-height: 0;
    }
  }
</style>
