---
const { site } = Astro.props;
import IconBadge from "./IconBadge.astro";

const a = site.about ?? {};

const title = a.title ?? "About";
const intro =
  a.intro ??
  "NexGen Binary delivers practical IT support for dental and healthcare practices that value secure systems, responsive service, and clear communication.";

const cards = [
  {
    icon: "people",
    title: "Who We Are",
    lede:
      "We are a Virginia-based IT partner serving dental and healthcare practices with dependable support, practical guidance, and a people-first approach.",
    bullets: [
      "Support shaped around clinical, front-office, and admin workflows",
      "Long-term relationships built on clarity, reliability, and follow-through",
    ],
  },
  {
    icon: "tools",
    title: "Dental & Healthcare Focus",
    lede:
      "Our support is designed for environments where uptime, coordination, and everyday usability matter.",
    bullets: [
      "Support across front-office, clinical, and admin systems",
      "Coordination with providers, office managers, and vendors",
      "Planning that reduces disruption during upgrades and transitions",
    ],
  },
  {
    icon: "shield",
    title: "Security & Compliance by Design",
    bullets: [
      "HIPAA-aware IT practices backed by security-minded planning",
      "Secure access, encryption, backups, and device protection",
      "Documented changes, vendor coordination, and accountability",
      "Cybersecurity safeguards aligned to uptime and continuity",
    ],
  },
  {
    icon: "checkcircle",
    title: "Leadership & Delivery Experience",
    lede:
      "Our team brings more than 20 years of combined IT leadership and delivery experience, with structured onboarding and clear next steps.",
    bullets: [
      "Licensed and insured service backed by professionalism",
      "Enterprise discipline delivered with local responsiveness",
      "Recommendations supported by documentation and follow-through",
    ],
  },
];
---
<section id="about" class="nb-anchor-offset nb-section nb-about-section" style="background:#f8fafc">
  <div class="nb-shell">
    <div class="nb-section-header nb-section-header--left nb-about-header">
      <h2 class="nb-section-title">{title}</h2>
      <p class="nb-section-subtitle nb-about-intro">{intro}</p>
    </div>

    <div class="nb-about-grid">
      {cards.map((card) => (
        <article class="nb-card nb-pop bg-white nb-about-panel">
          <div class="nb-about-panel__head">
            <div class="nb-icon-wrap nb-about-panel__icon"><IconBadge name={card.icon} /></div>
            <h3 class="nb-about-panel__title">{card.title}</h3>
          </div>

          <div class="nb-about-panel__body">
            {card.lede && <p class="nb-about-panel__lede">{card.lede}</p>}

            {card.bullets && card.bullets.length > 0 && (
              <ul class="nb-about-panel__list">
                {card.bullets.map((item) => <li>{item}</li>)}
              </ul>
            )}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .nb-about-header {
    margin-bottom: 1rem;
  }

  .nb-about-intro {
    max-width: 900px;
    color: #5b6f84;
    font-size: clamp(1rem, 1.02vw, 1.08rem);
    line-height: 1.46;
    letter-spacing: 0.004em;
  }

  .nb-about-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    align-items: stretch;
    grid-auto-rows: 1fr;
  }

  .nb-about-panel {
    min-height: 250px;
    border-radius: 22px;
    padding: 1.15rem 1.2rem 1.08rem;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .nb-about-panel__head {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 0.48rem;
  }

  .nb-about-panel__icon {
    width: 52px;
    height: 52px;
    min-width: 52px;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 0;
  }

  .nb-about-panel__icon :global(.nb-icon-badge),
  .nb-about-panel__icon :global(.nb-icon-badge svg) {
    width: 26px;
    height: 26px;
    display: block;
  }

  .nb-about-panel__title {
    margin: 0;
    color: #163659;
    font-size: 1.04rem;
    line-height: 1.24;
    letter-spacing: -0.005em;
    font-weight: 700;
  }

  .nb-about-panel__body {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }

  .nb-about-panel__lede {
    margin: 0;
    color: #4f6377;
    line-height: 1.48;
  }

  .nb-about-panel__list {
    margin: 0;
    padding-left: 1.14rem;
    display: grid;
    gap: 0.44rem;
  }

  .nb-about-panel__list li {
    color: #4f6377;
    line-height: 1.38;
  }

  .nb-about-panel__list li::marker {
    color: #4c6177;
  }

  @media (max-width: 991px) {
    .nb-about-grid {
      grid-template-columns: 1fr;
    }

    .nb-about-panel {
      min-height: 0;
    }
  }
</style>
