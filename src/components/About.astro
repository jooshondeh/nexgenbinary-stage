---
const { site } = Astro.props;
import IconBadge from "./IconBadge.astro";

const a = site.about ?? {};

const intro =
  a.intro ??
  "Practical IT partnership for dental and healthcare practices that value secure systems, reliable support, and clear communication.";

const defaultCards = [
  {
    icon: "people",
    title: "Who We Are",
    items: [
      "Virginia-based IT partner serving dental and healthcare practices throughout Virginia",
      "People-first support built on responsiveness, reliability, and follow-through",
      "Practical guidance shaped by real clinical, front-office, and administrative workflows",
      "Long-term partnerships focused on stability, clarity, and usable outcomes",
    ],
  },
  {
    icon: "tools",
    title: "Dental & Healthcare Focus",
    items: [
      "Support for front-office, clinical, and administrative technology environments",
      "Coordination with providers, office managers, and third-party vendors",
      "Planning that helps reduce disruption during upgrades, transitions, and change",
      "Solutions aligned to practice operations, growth, and patient-facing service",
    ],
  },
  {
    icon: "shield",
    title: "Security & Compliance by Design",
    items: [
      "HIPAA-aware IT practices supported by security-minded system planning",
      "Secure access, encryption, backup strategy, and device protection",
      "Documented configurations, vendor coordination, and accountable change management",
      "Cybersecurity safeguards aligned to operational risk and business continuity",
    ],
  },
  {
    icon: "checkcircle",
    title: "Leadership & Delivery Experience",
    items: [
      "More than 20 years of combined IT leadership and service delivery experience",
      "Structured onboarding, clear recommendations, and documented next steps",
      "Licensed and insured service backed by professionalism and accountability",
      "Enterprise-level discipline delivered with local responsiveness and support",
    ],
  },
];

const cards = Array.isArray(a.cards) && a.cards.length ? a.cards : defaultCards;
---
<section id="about" class="nb-anchor-offset nb-section nb-about-section" style="background:#f8fafc">
  <div class="container">
    <div class="nb-about-header">
      <h2 class="section-title fw-bold mb-0">{a.title ?? "About"}</h2>
      <p class="nb-about-intro mb-0">{intro}</p>
    </div>

    <div class="row g-4 nb-about-grid">
      {cards.map((card) => (
        <div class="col-lg-6">
          <article class="nb-card nb-pop bg-white nb-about-panel">
            <div class="nb-about-panel__head">
              <div class="nb-icon-wrap nb-about-panel__icon"><IconBadge name={card.icon} /></div>
              <h3 class="nb-about-panel__title">{card.title}</h3>
            </div>

            <ul class="nb-about-panel__list">
              {(card.items ?? []).map((item) => <li>{item}</li>)}
            </ul>
          </article>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .nb-about-header {
    margin-bottom: 1.15rem;
  }

  .nb-about-intro {
    max-width: 860px;
    color: #5b6f84;
    font-size: clamp(1.02rem, 1.08vw, 1.14rem);
    line-height: 1.5;
    letter-spacing: 0.01em;
  }

  .nb-about-grid {
    align-items: stretch;
  }

  .nb-about-panel {
    height: 100%;
    min-height: 250px;
    border-radius: 22px;
    padding: 1.2rem 1.2rem 1.1rem;
    display: flex;
    flex-direction: column;
  }

  .nb-about-panel__head {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 0.45rem;
  }

  .nb-about-panel__icon {
    width: 52px;
    height: 52px;
    min-width: 52px;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 0;
  }

  .nb-about-panel__icon :global(.nb-icon-badge) {
    width: 24px;
    height: 24px;
  }

  .nb-about-panel__icon :global(.nb-icon-badge svg) {
    width: 24px;
    height: 24px;
    display: block;
  }

  .nb-about-panel__title {
    margin: 0;
    color: #163659;
    font-size: 1.04rem;
    line-height: 1.24;
    letter-spacing: -0.005em;
    font-weight: 700;
  }

  .nb-about-panel__list {
    margin: 0.45rem 0 0;
    padding-left: 1.18rem;
    display: grid;
    gap: 0.5rem;
  }

  .nb-about-panel__list li {
    color: #4f6377;
    line-height: 1.44;
  }

  .nb-about-panel__list li::marker {
    color: #4c6177;
  }

  @media (max-width: 991px) {
    .nb-about-header {
      margin-bottom: 1rem;
    }

    .nb-about-panel {
      min-height: 0;
    }
  }
</style>
