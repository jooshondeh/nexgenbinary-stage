---
const { site } = Astro.props;
import IconBadge from "./IconBadge.astro";

const w = site.whoWeServe ?? {};

const intro =
  w.intro ??
  "We support dental practices across Virginia with IT services built around clinical workflows, front-desk uptime, secure access, and reliable daily operations.";

const defaultCards = [
  {
    icon: "people",
    title: "Practices We Support",
    items: [
      "Single-location offices needing dependable day-to-day IT",
      "Growing multi-provider or multi-site practices needing scalable IT",
      "New or expanding offices planning cloud, infrastructure, or upgrades",
      "Practices seeking one accountable IT and security partner",
    ],
  },
  {
    icon: "tools",
    title: "Clinical & Office Environments",
    items: [
      "Front-desk, scheduling, billing, and admin workstations",
      "Operatories, provider areas, and shared clinical devices",
      "Imaging-connected environments needing stable, secure networks",
      "Microsoft 365 and cloud tools that support office operations",
    ],
  },
  {
    icon: "shield",
    title: "How We Support Practices",
    items: [
      "Workflow-aware support designed to reduce office disruption",
      "Proactive maintenance and monitoring that help prevent downtime",
      "Secure remote support with on-site help when needed",
      "Clear coordination with staff, vendors, and practice leadership",
    ],
  },
  {
    icon: "pin",
    title: "Virginia Coverage & Delivery Model",
    items: [
      "Richmond-based support with service across Virginia",
      "Remote-friendly service for faster response and resolution",
      "On-site visits for projects, upgrades, assessments, and urgent needs",
      "Ongoing partnership built on responsiveness and follow-through",
    ],
  },
];

const cards = Array.isArray(w.cards) && w.cards.length ? w.cards : defaultCards;
---
<section id="who-we-serve" class="nb-anchor-offset nb-section nb-who-section" style="background:#ffffff">
  <div class="nb-shell">
    <div class="nb-section-header nb-section-header--left nb-who-header">
      <h2 class="nb-section-title">{w.title ?? "Who We Serve"}</h2>
      <p class="nb-section-subtitle nb-who-intro">{intro}</p>
    </div>

    <div class="nb-who-grid">
      {cards.map((card) => (
        <article class="nb-card nb-pop bg-white nb-who-panel">
          <div class="nb-who-panel__head">
            <div class="nb-icon-wrap nb-who-panel__icon"><IconBadge name={card.icon} /></div>
            <h3 class="nb-who-panel__title">{card.title}</h3>
          </div>

          <ul class="nb-who-panel__list">
            {(card.items ?? []).map((item) => <li>{item}</li>)}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .nb-who-header {
    margin-bottom: 1rem;
  }

  .nb-who-intro {
    max-width: 880px;
    color: #5b6f84;
    font-size: clamp(1rem, 1.02vw, 1.1rem);
    line-height: 1.46;
    letter-spacing: 0.004em;
  }

  .nb-who-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    align-items: stretch;
    grid-auto-rows: 1fr;
  }

  .nb-who-panel {
    min-height: 272px;
    border-radius: 22px;
    padding: 1.16rem 1.18rem 1.04rem;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .nb-who-panel__head {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 0.44rem;
  }

  .nb-who-panel__icon {
    width: 52px;
    height: 52px;
    min-width: 52px;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 0;
  }

  .nb-who-panel__icon :global(.nb-icon-badge),
  .nb-who-panel__icon :global(.nb-icon-badge svg) {
    width: 26px;
    height: 26px;
    display: block;
  }

  .nb-who-panel__title {
    margin: 0;
    color: #163659;
    font-size: 1.04rem;
    line-height: 1.24;
    letter-spacing: -0.005em;
    font-weight: 700;
  }

  .nb-who-panel__list {
    margin: 0.48rem 0 0;
    padding-left: 1.14rem;
    display: grid;
    gap: 0.46rem;
  }

  .nb-who-panel__list li {
    color: #4f6377;
    line-height: 1.38;
  }

  .nb-who-panel__list li::marker {
    color: #4c6177;
  }

  @media (max-width: 991px) {
    .nb-who-grid {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .nb-who-panel {
      min-height: 0;
    }
  }
</style>
