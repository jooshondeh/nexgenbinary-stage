---
const { site } = Astro.props;
import IconBadge from "./IconBadge.astro";

const w = site.whoWeServe ?? {};

const intro =
  w.intro ??
  "We support dental practices across Virginia with IT services aligned to clinical workflows, front-office uptime, security expectations, and everyday practice operations.";

const defaultCards = [
  {
    icon: "people",
    title: "Practices We Support",
    items: [
      "Single-location offices that need dependable day-to-day IT support",
      "Growing multi-provider and multi-site practices preparing to scale systems and support",
      "New and expanding offices planning cloud, infrastructure, or technology rollouts",
      "Practices seeking one accountable partner across IT, security, and vendor coordination",
    ],
  },
  {
    icon: "tools",
    title: "Clinical & Office Environments",
    items: [
      "Front-desk, scheduling, billing, and administrative workstations",
      "Operatories, provider work areas, and shared clinical devices",
      "Imaging-connected environments that rely on stable networks and secure access",
      "Microsoft 365, cloud, and collaboration tools that keep office operations moving",
    ],
  },
  {
    icon: "shield",
    title: "How We Support Practices",
    items: [
      "Workflow-aware support designed to minimize disruption during office hours",
      "Proactive maintenance and monitoring that reduce avoidable downtime",
      "Secure remote support with on-site capability when needed",
      "Clear coordination with staff, vendors, and practice leadership",
    ],
  },
  {
    icon: "pin",
    title: "Virginia Coverage & Delivery Model",
    items: [
      "Richmond-based support with service coverage across Virginia",
      "Remote-friendly service for fast response and efficient issue resolution",
      "On-site visits for projects, upgrades, assessments, and higher-priority needs",
      "Long-term partnership built on responsiveness, documentation, and follow-through",
    ],
  },
];

const cards = Array.isArray(w.cards) && w.cards.length ? w.cards : defaultCards;
---
<section id="who-we-serve" class="nb-anchor-offset nb-section nb-who-section" style="background:#ffffff">
  <div class="container">
    <div class="nb-who-header">
      <h2 class="section-title fw-bold mb-0">{w.title ?? "Who We Serve"}</h2>
      <p class="nb-who-intro mb-0">{intro}</p>
    </div>

    <div class="row g-4 nb-who-grid">
      {cards.map((card) => (
        <div class="col-lg-6">
          <article class="nb-card nb-pop bg-white nb-who-panel">
            <div class="nb-who-panel__head">
              <div class="nb-icon-wrap nb-who-panel__icon"><IconBadge name={card.icon} /></div>
              <h3 class="nb-who-panel__title">{card.title}</h3>
            </div>

            <ul class="nb-who-panel__list">
              {(card.items ?? []).map((item) => <li>{item}</li>)}
            </ul>
          </article>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .nb-who-header {
    margin-bottom: 1.15rem;
  }

  .nb-who-intro {
    max-width: 860px;
    color: #5b6f84;
    font-size: clamp(1.02rem, 1.08vw, 1.14rem);
    line-height: 1.5;
    letter-spacing: 0.01em;
  }

  .nb-who-grid {
    align-items: stretch;
  }

  .nb-who-panel {
    height: 100%;
    min-height: 250px;
    border-radius: 22px;
    padding: 1.2rem 1.2rem 1.1rem;
    display: flex;
    flex-direction: column;
  }

  .nb-who-panel__head {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 0.45rem;
  }

  .nb-who-panel__icon {
    width: 52px;
    height: 52px;
    min-width: 52px;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 0;
  }

  .nb-who-panel__icon :global(.nb-icon-badge) {
    width: 24px;
    height: 24px;
  }

  .nb-who-panel__icon :global(.nb-icon-badge svg) {
    width: 24px;
    height: 24px;
    display: block;
  }

  .nb-who-panel__title {
    margin: 0;
    color: #163659;
    font-size: 1.04rem;
    line-height: 1.24;
    letter-spacing: -0.005em;
    font-weight: 700;
  }

  .nb-who-panel__list {
    margin: 0.45rem 0 0;
    padding-left: 1.18rem;
    display: grid;
    gap: 0.5rem;
  }

  .nb-who-panel__list li {
    color: #4f6377;
    line-height: 1.44;
  }

  .nb-who-panel__list li::marker {
    color: #4c6177;
  }

  @media (max-width: 991px) {
    .nb-who-header {
      margin-bottom: 1rem;
    }

    .nb-who-panel {
      min-height: 0;
    }
  }
</style>
