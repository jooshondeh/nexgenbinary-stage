---
const { site } = Astro.props;
import IconBadge from "./IconBadge.astro";

const w = site.whoWeServe ?? {};

const title = w.title ?? "Who We Serve";
const intro =
  w.intro ??
  "We support dental practices across Virginia with IT services built around clinical workflows, front-desk uptime, secure access, and reliable daily operations.";

const cards = [
  {
    icon: "people",
    title: "Practices We Support",
    lede:
      "We work with single-location dental offices, growing multi-provider teams, and expanding practices that need dependable day-to-day support as well as clear technology planning.",
  },
  {
    icon: "tools",
    title: "Clinical & Office Environments",
    bullets: [
      "Front-desk, scheduling, billing, and admin workstations",
      "Operatories, provider areas, and shared clinical devices",
      "Imaging-connected environments that need stable, secure access",
      "Microsoft 365 and cloud tools that support office operations",
    ],
  },
  {
    icon: "shield",
    title: "How We Support Practices",
    lede:
      "Our support model is built to reduce disruption during office hours while keeping systems secure, maintained, and responsive.",
    bullets: [
      "Proactive maintenance and monitoring that help prevent downtime",
      "Secure remote support with on-site help when needed",
      "Clear coordination with staff, vendors, and practice leadership",
    ],
  },
  {
    icon: "pin",
    title: "Virginia Coverage & Delivery Model",
    lede:
      "We provide Richmond-based support with coverage across Virginia, combining remote-friendly service for fast response with on-site visits for projects, assessments, upgrades, and urgent needs.",
  },
];
---
<section id="who-we-serve" class="nb-anchor-offset nb-section nb-who-section" style="background:#ffffff">
  <div class="nb-shell">
    <div class="nb-section-header nb-section-header--left nb-who-header">
      <h2 class="nb-section-title">{title}</h2>
      <p class="nb-section-subtitle nb-who-intro">{intro}</p>
    </div>

    <div class="nb-who-grid">
      {cards.map((card) => (
        <article class="nb-card nb-pop bg-white nb-who-panel">
          <div class="nb-who-panel__head">
            <div class="nb-icon-wrap nb-who-panel__icon"><IconBadge name={card.icon} /></div>
            <h3 class="nb-who-panel__title">{card.title}</h3>
          </div>

          <div class="nb-who-panel__body">
            {card.lede && <p class="nb-who-panel__lede">{card.lede}</p>}

            {card.bullets && card.bullets.length > 0 && (
              <ul class="nb-who-panel__list">
                {card.bullets.map((item) => <li>{item}</li>)}
              </ul>
            )}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .nb-who-header {
    margin-bottom: 1rem;
  }

  .nb-who-intro {
    max-width: 880px;
    color: #5b6f84;
    font-size: clamp(1rem, 1.02vw, 1.1rem);
    line-height: 1.46;
    letter-spacing: 0.004em;
  }

  .nb-who-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    align-items: stretch;
    grid-auto-rows: 1fr;
  }

  .nb-who-panel {
    min-height: 292px;
    border-radius: 22px;
    padding: 1.18rem 1.2rem 1.08rem;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .nb-who-panel__head {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 0.5rem;
  }

  .nb-who-panel__icon {
    width: 52px;
    height: 52px;
    min-width: 52px;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 0;
  }

  .nb-who-panel__icon :global(.nb-icon-badge),
  .nb-who-panel__icon :global(.nb-icon-badge svg) {
    width: 26px;
    height: 26px;
    display: block;
  }

  .nb-who-panel__title {
    margin: 0;
    color: #163659;
    font-size: 1.04rem;
    line-height: 1.24;
    letter-spacing: -0.005em;
    font-weight: 700;
  }

  .nb-who-panel__body {
    display: flex;
    flex-direction: column;
    gap: 0.58rem;
  }

  .nb-who-panel__lede {
    margin: 0;
    color: #4f6377;
    line-height: 1.5;
  }

  .nb-who-panel__list {
    margin: 0;
    padding-left: 1.14rem;
    display: grid;
    gap: 0.48rem;
  }

  .nb-who-panel__list li {
    color: #4f6377;
    line-height: 1.4;
  }

  .nb-who-panel__list li::marker {
    color: #4c6177;
  }

  @media (max-width: 991px) {
    .nb-who-grid {
      grid-template-columns: 1fr;
    }

    .nb-who-panel {
      min-height: 0;
    }
  }
</style>
