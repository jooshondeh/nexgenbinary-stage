---
import IconBadge from './IconBadge.astro';
const { site } = Astro.props;
const groups = site?.services?.groups ?? [];
const servicesIntro =
  site?.services?.subtitle ||
  'Managed IT, security, cloud, networking, and website support tailored to the day-to-day needs of modern dental practices across Virginia.';

const iconFor = (title = '') => {
  const t = title.toLowerCase();
  if (t.includes('managed')) return 'monitor';
  if (t.includes('emr') || t.includes('clinical')) return 'tools';
  if (t.includes('microsoft') || t.includes('cloud')) return 'cloud';
  if (t.includes('security')) return 'lockshield';
  if (t.includes('website') || t.includes('hosting') || t.includes('digital presence')) return 'globe';
  if (t.includes('network') || t.includes('wifi') || t.includes('wi‑fi') || t.includes('voip') || t.includes('camera')) return 'network';
  return 'tools';
};

const serviceItemText = (item) => {
  if (item == null) return '';
  if (typeof item === 'string' || typeof item === 'number') return String(item);
  if (Array.isArray(item)) return item.map(serviceItemText).filter(Boolean).join(' ');
  if (typeof item === 'object') {
    for (const key of ['text', 'label', 'title', 'name', 'value', 'description', 'desc']) {
      if (typeof item[key] === 'string' || typeof item[key] === 'number') return String(item[key]);
    }
    return Object.values(item)
      .filter((v) => typeof v === 'string' || typeof v === 'number')
      .map((v) => String(v).trim())
      .filter(Boolean)
      .join(' ');
  }
  return String(item);
};

const normalizeItems = (items = []) => (items ?? []).map(serviceItemText).filter(Boolean);
---
<section id="services" class="nb-section nb-anchor-offset">
  <div class="nb-shell">
    <div class="nb-section-header nb-section-header--left">
      <h2 class="nb-section-title">{site?.services?.title || 'Services'}</h2>
      <p class="nb-section-subtitle nb-services-intro">{servicesIntro}</p>
    </div>

    <div class="nb-services-grid">
      {groups.map((group) => (
        <article class="nb-service-card nb-hover-pop nb-service-card-standard">
          <div class="nb-service-head">
            <div class="nb-icon-wrap"><IconBadge name={iconFor(group.title)} /></div>
            <h3>{group.title}</h3>
          </div>
          <ul>
            {normalizeItems(group.items ?? []).map((item) => <li>{item}</li>)}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>
